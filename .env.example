# .env.example — copy to .env and fill in values
# All variables are optional except ZAI_API_KEY (required for LLM calls)

# ── Z.AI (GLM models) — required for primary LLM ───────────────────────────
# Get key: https://z.ai/manage-apikey · API docs: https://docs.z.ai/api-reference/introduction
ZAI_API_KEY=your_zai_key
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_MODEL=glm-4-plus

# ── FLock (fallback / open-source models) ──────────────────────────────────
# Used when Z.AI fails after 3 retries. API: https://docs.flock.io/flock-products/api-platform/api-endpoint
FLOCK_API_KEY=your_flock_key
FLOCK_BASE_URL=https://api.flock.io/v1
FLOCK_MODEL=deepseek-v3

# ── Anyway SDK (tracing / observability) ────────────────────────────────────
ANYWAY_API_KEY=your_anyway_key
ANYWAY_PROJECT_ID=your_project_id
ANYWAY_BASE_URL=https://api.anyway.so/v1
ANYWAY_ENABLED=false

# ── Stripe (payments / monetisation) ───────────────────────────────────────
STRIPE_SECRET_KEY=your_stripe_key
STRIPE_CONNECT_ACCOUNT_ID=your_account_id

# ── App ────────────────────────────────────────────────────────────────────
PORT=8000
FRONTEND_URL=http://localhost:3000
LOG_DIR=./logs
CORS_ORIGINS=*

# ── SQLite conversation store ──────────────────────────────────────────────
CONVERSATIONS_DB_PATH=./data/conversations.db

# ── Rate limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_MINUTES=10

# ── Frontend (Next.js) ──────────────────────────────────────────────────────
# API base URL for frontend requests (default: http://localhost:8000)
NEXT_PUBLIC_API_URL=http://localhost:8000
